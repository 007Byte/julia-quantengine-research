# QuantEngine TradingSwarm Configuration
# Copy to .env and fill in values.

# ---- Environment ----
QE_ENVIRONMENT=dev              # dev | paper | live
QE_INSTANCE_ID=qe-dev-01

# ---- Postgres ----
QE_PG_HOST=localhost
QE_PG_PORT=5432
QE_PG_DATABASE=quantengine
QE_PG_USER=quantengine
QE_PG_PASSWORD=

# ---- Redis ----
QE_REDIS_HOST=localhost
QE_REDIS_PORT=6379
QE_REDIS_PASSWORD=

# ---- Julia Bridge ----
QE_JULIA_ENDPOINT=tcp://127.0.0.1:5555

# ---- Risk Limits ----
QE_MAX_DAILY_LOSS_PCT=0.05
QE_MAX_DRAWDOWN_PCT=0.15

# ---- Teams ----
QE_ENABLED_TEAMS=crypto

# ---- Broker Credentials (never commit real values) ----
# QE_BINANCE_API_KEY=
# QE_BINANCE_API_SECRET=
# QE_ALPACA_API_KEY=
# QE_ALPACA_API_SECRET=
# QE_POLYMARKET_API_KEY=
# QE_POLYMARKET_SIGNING_KEY=
# QE_OANDA_API_TOKEN=

# ---- Monitoring ----
# QE_ALERT_WEBHOOK_URL=
