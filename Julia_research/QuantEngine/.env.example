# ── QuantEngine Environment Variables ──
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Execution Mode ──
# PAPER (default) or LIVE — must be explicitly set to LIVE for real trading
QE_EXECUTION_MODE=PAPER

# ── Capital & Risk ──
QE_INITIAL_BANKROLL=2000
QE_MAX_POSITION_PCT=0.10
QE_MAX_DAILY_LOSS_PCT=0.05
QE_MAX_DRAWDOWN_PCT=0.15
QE_MAX_CONCURRENT_POS=5

# ── Pipeline Behavior ──
QE_POLL_INTERVAL_MS=5000
QE_DATA_LOOKBACK_DAYS=90
QE_FEE_RATE=0.02
QE_FORCE_CONSERVATIVE=false
QE_COOLING_PERIOD=10

# ── Trigger Thresholds ──
QE_VOLUME_SPIKE_MULT=3.0
QE_OB_IMBALANCE_THRESH=0.70
QE_PRICE_JUMP_THRESH=0.03

# ── Pipeline Gates ──
QE_CALIBRATION_GAP_MAX=0.10
QE_EV_GAP_MIN=0.05
QE_KELLY_MIN_FRAC=0.25
QE_KELLY_MAX_FRAC=0.50

# ── API Keys ──
# Polymarket (required for prediction market data)
POLYMARKET_API_KEY=your_polymarket_key_here

# Alpaca (required for real stock trading — Sprint 5)
# QE_ALPACA_API_KEY=your_alpaca_key_here
# QE_ALPACA_SECRET_KEY=your_alpaca_secret_here

# Polygon.io (required for real-time stock data — Sprint 6)
# QE_POLYGON_API_KEY=your_polygon_key_here

# Binance (required for real crypto trading — Sprint 5)
# QE_BINANCE_API_KEY=your_binance_key_here
# QE_BINANCE_SECRET_KEY=your_binance_secret_here

# X/Twitter (required for sentiment streaming — Sprint 9)
# QE_X_BEARER_TOKEN=your_x_bearer_token_here

# ── Output ──
# Override default output directory (default: ~/Documents/Quant_Analysis/)
# QUANT_OUTPUT_DIR=/path/to/custom/output
